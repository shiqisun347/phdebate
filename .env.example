PHDEBATE_ENV=development
PHDEBATE_AUTH_REQUIRED=0
PHDEBATE_BASE_URL=http://localhost:8000
PHDEBATE_DATABASE_URL=sqlite:///apps/backend/storage/phdebate.sqlite3
PHDEBATE_AUDIO_DIR=apps/backend/storage/audio
PHDEBATE_ADMIN_PASSWORD=admin
PHDEBATE_HOST_PASSWORD=host
PHDEBATE_SCREEN_TOKEN=screen-dev-token
PHDEBATE_SPEAKER_TOKEN=speaker-dev-token
PHDEBATE_SPEAKER_TOKENS={"spk_aff_3":"aff3-dev-token","spk_neg_2":"neg2-dev-token"}
PHDEBATE_AGENT_SHARED_TOKEN=agent-dev-token
PHDEBATE_AGENT_BASE_URL=http://127.0.0.1:8100
PHDEBATE_AGENT_CONNECT_TIMEOUT_MS=3000
PHDEBATE_AGENT_READ_TIMEOUT_MS=30000
MOCK_AGENT_PROFILE=normal
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=
XFYUN_ASR_URL=
XFYUN_TTS_URL=
