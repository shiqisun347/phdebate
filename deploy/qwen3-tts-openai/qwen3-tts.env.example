# Qwen3-TTS service tuned for phdebate/live web playback.
QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
QWEN_TTS_DEVICE=cuda
QWEN_TTS_DTYPE=bfloat16
CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# Use hf-mirror / local cache on mainland China servers.
HF_ENDPOINT=https://hf-mirror.com
HF_HOME=/root/autodl-tmp/qwen3-tts-openai/models
HUGGINGFACE_HUB_CACHE=/root/autodl-tmp/qwen3-tts-openai/models/hub
HF_HUB_DISABLE_XET=1
HF_HUB_DOWNLOAD_TIMEOUT=600

# Local service settings. phdebate calls this on 127.0.0.1:12302.
HOST=127.0.0.1
PORT=12302
NO_PROXY=localhost,127.0.0.1

# Stable live-debate profile.
QWEN_TTS_LANGUAGE=Chinese
QWEN_TTS_DEFAULT_VOICE=Dylan
QWEN_TTS_RESPONSE_FORMAT=mp3
QWEN_TTS_CHUNK_SIZE=8
QWEN_TTS_SEGMENT_CHARS=260
QWEN_TTS_MAX_TEXT_CHARS=4000
QWEN_TTS_MAX_NEW_TOKENS=2048
QWEN_TTS_MP3_BITRATE=64k

# Single GPU: serialize generation and absorb bursts with a bounded queue.
QWEN_TTS_MAX_QUEUE_WAITERS=64
QWEN_TTS_QUEUE_TIMEOUT_SECONDS=600
QWEN_TTS_INTERNAL_QUEUE_CHUNKS=64
QWEN_TTS_WARMUP=1
LOG_LEVEL=INFO
