PHDEBATE_ENV=production
PHDEBATE_AUTH_REQUIRED=1
PHDEBATE_BASE_URL=http://127.0.0.1:6006
PHDEBATE_DATABASE_URL=sqlite:///apps/backend/storage/phdebate.sqlite3
PHDEBATE_AUDIO_DIR=apps/backend/storage/audio

PHDEBATE_LIVEKIT_ENABLED=1
PHDEBATE_LIVEKIT_MODE=cloud
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

PHDEBATE_VOICE_AGENT_BASE_URL=http://127.0.0.1:6008
PHDEBATE_LOCAL_ASR_BASE_URL=http://127.0.0.1:12301
PHDEBATE_LOCAL_TTS_BASE_URL=http://127.0.0.1:12302

PHDEBATE_TTS_FORMAL=1
PHDEBATE_ASR_REALTIME=1
PHDEBATE_ASR_AUTO_RECOGNIZE=1
PHDEBATE_TTS_SENTENCE_CONCURRENCY=2
PHDEBATE_TTS_EARLY_SEGMENT_CHARS=42
PHDEBATE_TTS_MIN_SENTENCE_CHARS=14
PHDEBATE_TTS_LIVE_STREAM=0
